# PostgreSQL connection string used by Prisma (Req 1.10 / 1.12)
DATABASE_URL="postgresql://user:password@localhost:5432/study_materials?schema=public"

# HTTP listen port (Req 1.10). Optional; defaults to 3000.
PORT="4001"

# Secret used to sign/verify learner and admin JWTs.
JWT_SECRET="change-me"

# Admin session lifetime in seconds. Optional; defaults to 3600 (1 hour).
ADMIN_TOKEN_TTL_SECONDS="3600"

# Cloudflare R2 (S3-compatible) object storage credentials and location (Req 1.13).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT=""

# Lifetime of download presigned URLs in seconds. Optional; defaults to 900 (15 min).
PRESIGNED_URL_TTL_SECONDS="900"

# Razorpay credentials (Req 12.12, 12.13, 12.17). REQUIRED in Phase 2 — the
# backend fails to start if any of these is absent or empty.
#   - RAZORPAY_KEY_ID:        non-secret Public Key Identifier (also used by the frontend)
#   - RAZORPAY_KEY_SECRET:    secret key; server-side only, never sent to the browser
#   - RAZORPAY_WEBHOOK_SECRET: secret used to verify Razorpay Webhook signatures
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
