{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "npm run reconcile",
    "cronSchedule": "*/30 * * * *",
    "restartPolicyType": "NEVER"
  },
  "variables": {
    "RAZORPAY_KEY_ID": "${{shared.RAZORPAY_KEY_ID}}",
    "RAZORPAY_KEY_SECRET": "${{shared.RAZORPAY_KEY_SECRET}}",
    "RAZORPAY_WEBHOOK_SECRET": "${{shared.RAZORPAY_WEBHOOK_SECRET}}",
    "DATABASE_URL": "${{shared.DATABASE_URL}}"
  }
}
