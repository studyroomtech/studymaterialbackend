# Local development environment variables (gitignored).

# When NODE_ENV=local, object storage uses the local filesystem instead of
# Cloudflare R2 (no cloud credentials needed). The database is always whatever
# DATABASE_URL points at below. Set to anything else (e.g. production) to use
# hosted R2.
NODE_ENV=local

# Replace with your own PostgreSQL connection string.
DATABASE_URL="postgresql://sm:sm@localhost:5432/study_materials?schema=public"






# Backend HTTP port. Kept distinct from the frontend (which runs on 4000)
# so the two dev servers don't collide.
PORT=4001

# Comma-separated browser origins allowed to call the API (CORS). The frontend
# dev server runs on 4000, so allow it here.
CORS_ORIGIN="http://localhost:4000"

# Razorpay credentials — required at boot in Phase 2 (Req 12.12, 12.13, 12.17).
# Replace with your own Razorpay test/live keys.
RAZORPAY_KEY_ID="rzp_test_TB3fah91mrEFzv"
RAZORPAY_KEY_SECRET="WirKIGkCyUQRtWGSsNHOmNB6"
# No webhook configured yet; kept non-empty so boot doesn't fail (fail-fast).
# Set this to the real secret when you add a webhook in the Razorpay dashboard.
RAZORPAY_WEBHOOK_SECRET="placeholder_webhook_secret"

JWT_SECRET='JWT_SECRET'